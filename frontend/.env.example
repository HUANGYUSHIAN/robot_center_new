# 內網（預設）：與先前相同，WebSocket 連 ws://<瀏覽器主機>:8765/ws
EXTERNAL=false

# 外網：設為 true 後（EXTERNAL=true）
# UseExternalNgrok=false（預設）：`npm run dev` 會自動啟動 ngrok，並在終端機顯示「ngrok URL: https://...」；覆寫 `frontend/.ngrok-url.txt`。
# UseExternalNgrok=true：`npm run dev` 跳過自動啟動 ngrok，你需要自行另開終端機執行 `ngrok http <PORT>`。
# Vite 會代理 `/ws` → 本機 TMUI server（預設 127.0.0.1:8765），請用 ngrok 的 HTTPS 網址開啟頁面。
# EXTERNAL=true

# 用外部（自行手動）ngrok：true/false
UseExternalNgrok=false

# ngrok（只有在 UseExternalNgrok=false 時才會被 npm run dev 自動啟動；建議填 token，與 turnserver 相同，可避免損壞的全域 ngrok.yml）
NGROK_AUTHTOKEN=
# NGROK_PATH=C:\路徑\ngrok.exe
# Twilio：託管 STUN/TURN（npm run twilio:ice），產生 .twilio-ice-servers.json
# TMUI 串流目前為 WebSocket，不需 TURN；此為延伸／除錯用。
Twilio_Auth_SID=
Twilio_Auth_Token=

# 可選：若 TMUI server 不在本機，改為 http://<ip>:8765
# TMUI_WS_PROXY_TARGET=http://127.0.0.1:8765

# Vite 與 ngrok 轉發埠（ngrok.cjs 讀 PORT 或 FRONTEND_PORT）
PORT=5173
